#!/bin/bash
# Pre-commit gate: block commits that would fail CI
# Install: git config core.hooksPath scripts
# Order: cheap gates first (fail fast), expensive last.

# Smoke-coverage gate: if this commit deletes an exact-match route, smoke.yml
# must not still reference the same literal path. Closes the "deleted route
# + forgotten smoke probe" loop (the 2026-04-26 /library/authors regression).
# Only gates exact-match routes (no :param, no *) — parametric routes are too
# soft to gate on; they're caught by the in-CI meta-loop step instead.
if git diff --cached --name-only | grep -qE '^server/src/.*\.ts$'; then
  DELETED_ROUTES=$(git diff --cached -U0 -- 'server/src/*.ts' \
    | grep -E '^-[[:space:]]*app\.(get|post|put|delete)[[:space:]]*\(' \
    | sed -nE "s/.*app\.(get|post|put|delete)\(\s*['\"]([^'\"]+)['\"].*/\2/p" \
    | grep -vE ':|\*' \
    | sort -u)
  SMOKE=.github/workflows/smoke.yml
  if [ -n "$DELETED_ROUTES" ] && [ -f "$SMOKE" ]; then
    blocked=0
    for r in $DELETED_ROUTES; do
      if grep -qE "\\\$SERVER${r}(\$|[^a-zA-Z0-9/_-])" "$SMOKE"; then
        echo "BLOCKED: this commit deletes route $r but $SMOKE still references \$SERVER$r"
        blocked=1
      fi
    done
    if [ $blocked -eq 1 ]; then
      echo ""
      echo "Fix: remove the matching probe from $SMOKE in this same commit."
      exit 1
    fi
  fi
fi

# Structural rule: every R2 content read (`.get(...)`) lives in file-access.ts.
# That module exports one read* helper per artifact type — each runs the
# appropriate visibility gate before returning bytes. A new route that does
# its own getR2().get(...) is reaching the bytes around the gate; this guard
# fails the commit so drift doesn't ship.
#
# Writes (.put), deletes (.delete), and list (.list) are governed by their
# own auth checks at the route boundary and are not in scope here.
if git diff --cached --name-only | grep -qE '^server/src/.*\.ts$'; then
  # 1. protocol/* R2 key construction — only file-access.ts (reads) and
  #    protocol.ts (writes via the auth-gated PUT) may build these.
  KEY_OFFENDERS=$(grep -lE 'protocol/\$\{' server/src/*.ts 2>/dev/null \
    | grep -vE 'server/src/(file-access|protocol)\.ts$' || true)
  if [ -n "$KEY_OFFENDERS" ]; then
    echo "BLOCKED: protocol_files R2 keys may only be built in file-access.ts (reads) or protocol.ts (writes)."
    echo "Violations:"
    echo "$KEY_OFFENDERS" | sed 's/^/  /'
    echo ""
    echo "Fix: route the new code through readProtocolFile() in file-access.ts."
    exit 1
  fi

  # 2. R2 content reads (`.get(...)`) — only file-access.ts may issue them.
  #    Routes get content by calling readProtocolFile / readShadow / readPulse
  #    / readQuizDefinition / readWork — all exported from file-access.ts.
  READ_OFFENDERS=$(grep -lE '(getR2\(\)|[^a-zA-Z_]r2)\.get\(' server/src/*.ts 2>/dev/null \
    | grep -vE 'server/src/file-access\.ts$' || true)
  if [ -n "$READ_OFFENDERS" ]; then
    echo "BLOCKED: R2 content reads (.get) may only happen in file-access.ts."
    echo "Violations:"
    echo "$READ_OFFENDERS" | sed 's/^/  /'
    echo ""
    echo "Fix: call one of the read*() helpers in file-access.ts. Do not call getR2().get directly."
    exit 1
  fi
fi

# Server type check (matches CI: "cd server && npm ci && npx tsc --noEmit")
if git diff --cached --name-only | grep -q '^server/src/'; then
  echo "server/src/ changed — type checking..."
  (cd server && npx tsc --noEmit)
  if [ $? -ne 0 ]; then
    echo ""
    echo "BLOCKED: server type errors. Fix before committing."
    exit 1
  fi
fi

# App build check (matches CI: "npm ci && npm run build")
if git diff --cached --name-only | grep -qE '^(app/|next\.config|package\.json)'; then
  echo "app/ changed — build checking..."
  npm run build 2>&1 | tail -20
  if [ ${PIPESTATUS[0]} -ne 0 ]; then
    echo ""
    echo "BLOCKED: app build failed. Fix before committing."
    exit 1
  fi
fi
